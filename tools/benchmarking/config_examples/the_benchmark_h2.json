{
  "timeout_sec": 600,
  "max_parallel_runs": 3,
  "domains_glob": "pddl/test_domains/*.pddl",
  "levels_dir": "pddl/test_problems/h2",
  "level_glob": "*.txt",
  "planner_settings": [
    {
      "name": "fd-lazy-fa",
      "family": "fa",
      "planner": "fd",
      "domain_include": ["*domain_FA_non-scanner_separated.pddl"],
      "planner_args": "--search \"let(hff, ff(), lazy_greedy([hff], preferred=[hff]))\""
    }
  ]
}
