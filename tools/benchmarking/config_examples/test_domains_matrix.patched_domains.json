{
  "timeout_sec": 60,
  "max_parallel_runs": 6,
  "random_seed": 1337,
  "domains": [
    "pddl/test_domains/domain_scanner_combined.pddl",
    "pddl/test_domains/domain_FA_scanner_combined.pddl",
    "pddl/test_domains/domain_FA_scanner_separated.pddl",
    "pddl/test_domains/domain_FA_non-scanner_combined.pddl",
    "pddl/test_domains/domain_FA_non-scanner_separated.pddl"
  ],
  "custom_fail_streak_limit": 2,
  "custom_levels_run_last": false,
  "repeat_successful_runs": 0,
  "growth_stop_on_failure": true,
  "stop_remaining_random_repeats_for_pair_on_failure": true,

  "growth": {
    "enabled": true,
    "start_size": 4,
    "max_size": 6,
    "size_step": 1,
    "required_gems": 1,
    "max_time_min": 200,
    "max_time_scale": 8
  },
  "random_repeats": {
    "enabled": true,
    "sizes": ["5x5"],
    "repeats_per_size": 1,
    "stone_counts": [4],
    "stone_count_mode": "cycle",
    "required_gems": 1,
    "max_time_min": 200,
    "max_time_scale": 8
  },
  "planner_settings": [
    {
      "name": "fd-lazy-greedy-classic",
      "family": "classic",
      "planner": "fd",
      "planner_args": "--search let(h,ff(),lazy_greedy([h],preferred=[h]))"
    },
    {
      "name": "fd-lazy-wastar-w1-classic",
      "family": "classic",
      "planner": "fd",
      "planner_args": "--search let(h,ff(),lazy_wastar([h],preferred=[h],w=1))"
    },
    {
      "name": "fd-lazy-wastar-w3-classic",
      "family": "classic",
      "planner": "fd",
      "planner_args": "--search let(h,ff(),lazy_wastar([h],preferred=[h],w=3))"
    },
    {
      "name": "fd-lazy-fa",
      "family": "fa",
      "planner": "fd",
      "planner_args": "--search let(h,ff(),lazy(single(h),preferred=[h]))"
    },
    {
      "name": "fd-lazy-greedy-fa",
      "family": "fa",
      "planner": "fd",
      "planner_args": "--search let(h,ff(),lazy_greedy([h],preferred=[h]))"
    },
    {
      "name": "fd-lazy-wastar-w1-fa",
      "family": "fa",
      "planner": "fd",
      "planner_args": "--search let(h,ff(),lazy_wastar([h],preferred=[h],w=1))"
    },
    {
      "name": "fd-lazy-wastar-w3-fa",
      "family": "fa",
      "planner": "fd",
      "planner_args": "--search let(h,ff(),lazy_wastar([h],preferred=[h],w=3))"
    }
  ]
}
