{
  "timeout_sec": 600,
  "max_parallel_runs": 2,
  "domains_glob": "pddl/test_domains_target/*.pddl",
  "levels_dir": "pddl/test_problems/h1",
  "level_glob": "*.txt",
  "planner_settings": [
    {
      "name": "fd-lazy-fa",
      "family": "fa",
      "planner": "fd",
      "domain_include": ["*domain_FA_scanner_combined.pddl"],
      "planner_args": "--search \"let(hff, ff(), lazy_greedy([hff], preferred=[hff]))\""
    }
  ]
}
